---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 | Debesh Blog">
  <section style="padding: 60px 0; text-align: center;">
    <h1 style="font-size: clamp(4rem, 10vw, 8rem); margin: 0; letter-spacing: -0.05em;">404</h1>
    <p style="font-family: 'IBM Plex Mono', monospace; margin: 12px 0 24px;">Page not found.</p>
    <a href={import.meta.env.BASE_URL} style="font-family: 'IBM Plex Mono', monospace; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.14em;">← Back to Console</a>
  </section>
</BaseLayout>
