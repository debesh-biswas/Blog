---
const title = 'About';
const description = 'About Debesh Blog and the ideas behind the site.';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Google+Sans+Code:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500;600&family=Instrument+Serif:ital@0;1&family=Space+Grotesk:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<script is:inline>
		  const storedTheme = localStorage.getItem('debesh-blog-theme');
		  const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
		  document.documentElement.dataset.theme = storedTheme ?? (systemPrefersDark ? 'dark' : 'light');
		</script>
		<title>{title} | Debesh Blog</title>
		<style>
			:root {
				--bg: #f0ede8;
				--surface: #e5e7ea;
				--ink: #151112;
				--ink-soft: #383336;
				--line: #a7a2a5;
			}

			html[data-theme='dark'] {
				color-scheme: dark;
				--bg: #0d0d11;
				--surface: #0f1116;
				--ink: #f2f0ee;
				--ink-soft: #d0ccd1;
				--line: #565259;
			}

			* { box-sizing: border-box; }
			html, body { margin: 0; min-height: 100%; }

			body {
				font-family: 'Space Grotesk', 'Segoe UI', sans-serif;
				background: var(--bg);
				color: var(--ink);
				line-height: 1.3;
			}

			main { max-width: 1320px; margin: 0 auto; padding: 18px 28px 30px; }

			a { color: inherit; text-decoration: none; }
			
			h1 {
				margin: 0 0 15px;
				font-size: clamp(2.2rem, 4vw, 3.8rem);
				line-height: 0.95;
				letter-spacing: -0.04em;
			}

			.topbar {
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 20px;
				padding: 10px 14px;
				border: 1px solid var(--line);
				margin-bottom: 18px;
				font-size: 0.72rem;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				font-family: 'IBM Plex Mono', monospace;
			}

			/* Explicit shared topbar typography to match homepage */
			.topbar,
			.topbar-block,
			.topbar-nav,
			.topbar-nav a {
				font-family: 'IBM Plex Mono', monospace;
				font-size: 0.72rem;
				letter-spacing: 0.2em;
				line-height: 1;
				text-transform: uppercase;
				font-weight: 600;
			}

			.topbar-middle { text-align: center; flex: 1; }

			.topbar-nav { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; justify-content: flex-end; }

			.theme-toggle {
				border: 1px solid var(--line);
				border-radius: 999px;
				background: transparent;
				color: var(--ink);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 40px;
				height: 40px;
				padding: 0;
				cursor: pointer;
			}

			.theme-toggle svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.8; }
			.theme-toggle .icon-sun { display: none; }
			html[data-theme='dark'] .theme-toggle .icon-sun { display: block; }
			html[data-theme='dark'] .theme-toggle .icon-moon { display: none; }

			.visually-hidden {
				position: absolute;
				width: 1px;
				height: 1px;
				padding: 0;
				margin: -1px;
				overflow: hidden;
				clip: rect(0, 0, 0, 0);
				white-space: nowrap;
				border: 0;
			}


		</style>
	</head>
	<body>
		<main>
			<header class="topbar" aria-label="Site top bar">
				<div class="topbar-block">Debesh Biswas - The <em>B</em>log</div>
				<div class="topbar-block topbar-middle">Artificial Intelligence / Machine Learning</div>
				<nav class="topbar-block topbar-nav" aria-label="Primary">
					<a href="/home/">Console</a>
					<a href="/blog/">Disk</a>
					<a href="/about">Root</a>
					<button class="theme-toggle" id="themeToggle" type="button" aria-label="Switch to dark mode">
						<svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M21 13.2A9 9 0 1 1 10.8 3a7 7 0 0 0 10.2 10.2z"></path>
						</svg>
						<svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true">
							<circle cx="12" cy="12" r="4"></circle>
							<path d="M12 2v3M12 19v3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M2 12h3M19 12h3M4.9 19.1 7 17M17 7l2.1-2.1"></path>
						</svg>
						<span class="visually-hidden">Toggle color theme</span>
					</button>
				</nav>
      		</header>
			<script is:inline>
			(function () {
				const ensureSetup = () => {
				const themeToggle = document.getElementById('themeToggle');

				const updateThemeToggleLabel = (activeTheme) => {
					if (!(themeToggle instanceof HTMLButtonElement)) return;
					themeToggle.setAttribute(
					'aria-label',
					activeTheme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'
					);
				};

				themeToggle?.addEventListener('click', () => {
					const nextTheme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
					document.documentElement.dataset.theme = nextTheme;
					localStorage.setItem('debesh-blog-theme', nextTheme);
					updateThemeToggleLabel(nextTheme);
				});

				updateThemeToggleLabel(document.documentElement.dataset.theme ?? 'light');
				};

				if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', ensureSetup);
				} else {
				ensureSetup();
				}
			})();
			</script>
			<section>
				<h1>Root</h1>
				<p>
					I'm a computer science grad from VIT now pursuing a Master's in Artificial Intelligence at Boston University, 
					and honestly, this field never stops surprising me, which is exactly why I'm hooked.
				</p>
				<p>	
					My interests live at the intersection of language, intelligence, and systems. I'm fascinated by how machines learn to understand context, 
					reason through ambiguity, and even generate creative output. 
					Large language models, multimodal AI, and agentic systems that can autonomously break down problems and act on them,
					these are the spaces where I think the most interesting problems live.
				</p>
				<p>	
					When I'm not deep in research or building, I'm tinkering with electronics, something I've picked up recently, catching up on papers, 
					or having a genuinely interesting conversation about something I don't fully understand yet. 
					I'm always open to internships and love chatting about AI, ideas, or anything in between.
				</p>
			</section>
			

		</main>
	</body>
</html>
