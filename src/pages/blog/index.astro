---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Blog';
const description = 'Posts, notes, and experiments for Debesh Blog.';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    day: 'numeric',
    month: 'short',
    year: 'numeric'
  }).format(date);

const getPostSlug = (post: (typeof posts)[number]) =>
  post.slug ?? post.id.replace(/\.mdx$/i, '').replace(/\/index$/i, '');

const postsByCategory = posts.reduce((acc, p) => {
  const cat = p.data.category ?? 'Uncategorized';
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(p);
  return acc;
}, {} as Record<string, Array<(typeof posts)[number]>>);

const categories = Object.keys(postsByCategory).sort((a, b) => a.localeCompare(b));
---

<BaseLayout title={`${title} | Debesh Blog`} description={description}>
  <section aria-label="Blog listing">
    <h1>Disk</h1>
    <p class="lead">Browse posts grouped by category below.</p>

    {categories.length === 0 ? (
      <p>No posts available.</p>
    ) : (
      categories.map((cat) => (
        <section class="category" aria-label={"Category: " + cat}>
          <h2 class="section-label">{cat}</h2>
          <ul class="post-list">
            {postsByCategory[cat]
              .slice()
              .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
              .map((post) => (
                <li>
                  <a class="post-link" href={`${import.meta.env.BASE_URL}blog/${getPostSlug(post)}/`}>{post.data.title}</a>
                  <span class="post-date">{post.data.pubDate ? formatDate(post.data.pubDate) : ''}</span>
                </li>
              ))}
          </ul>
        </section>
      ))
    )}
  </section>
</BaseLayout>

<style>
  h1 {
    margin: 0 0 15px;
    font-size: clamp(2.2rem, 4vw, 3.8rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .lead {
    margin: 0 0 26px;
    color: var(--muted);
    max-width: 60ch;
  }

  .post-list {
    list-style: none;
    margin: 0 0 20px 0;
    padding: 0;
  }

  .post-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 0;
  }

  .post-list li .post-link {
    flex: 1 1 auto;
    font-weight: 400;
    color: inherit;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 140ms ease, font-weight 120ms ease, transform 120ms ease;
  }

  .post-list li:hover .post-link,
  .post-list li .post-link:focus,
  .post-list li .post-link:focus-visible {
    font-weight: 600;
    transform: translateY(-1px);
    color: inherit;
  }

  .post-list li .post-date {
    flex: 0 0 auto;
    margin-left: 24px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.82rem;
    color: var(--ink-soft);
    white-space: nowrap;
  }

  .section-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 1.2rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 8px 0 6px;
  }

  .category {
    border-bottom: 1px solid var(--line);
    padding-bottom: 0;
    margin-bottom: 6px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .card {
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--surface);
    padding: 16px;
    min-height: 208px;
    display: flex;
    flex-direction: column;
  }

  .meta {
    display: inline-flex;
    gap: 10px;
    font-size: 0.72rem;
    font-family: 'IBM Plex Mono', monospace;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .card h2 {
    margin: 0 0 8px;
    font-size: 1.2rem;
    line-height: 1.1;
    min-height: 2.2em;
  }

  .card p {
    margin: 0;
    color: var(--muted);
    margin-top: auto;
  }

  @media (max-width: 760px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
