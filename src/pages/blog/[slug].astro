---
import { getCollection, render, type CollectionEntry } from 'astro:content';
type PostEntry = CollectionEntry<'blog'>;
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: {
      slug: post.slug ?? post.id.replace(/\.mdx$/i, '').replace(/\/index$/i, '')
    },
    props: { post }
  }));
}
const { post } = Astro.props as { post: PostEntry };
const { Content } = await render(post);
const pageTitle = `${post.data.title} | Debesh Blog`;
const pageDescription = post.data.excerpt;
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    day: 'numeric',
    month: 'short',
    year: 'numeric'
  }).format(date);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans+Code:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500;600&family=Instrument+Serif:ital@0;1&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <style>
      :root {
        --bg: #f0ede8;
        --surface: #fffaf4;
        --ink: #151112;
        --ink-soft: #383336;
        --line: #a7a2a5;
        --card-top: linear-gradient(180deg, #2d2a2c 0%, #161417 100%);
        --card-top-ink: #f2f2f2;
        --input-bg: #e5e7ea;
        --send-bg: #130f11;
        --send-ink: #f6f4f2;
      }

      html[data-theme='dark'] {
        color-scheme: dark;
        --bg: #0d0d11;
        --surface: #0f1116;
        --ink: #f2f0ee;
        --ink-soft: #d0ccd1;
        --line: #565259;
        --card-top: linear-gradient(180deg, #f0f0f0 0%, #d8dbe0 100%);
        --card-top-ink: #191519;
        --input-bg: #11131a;
        --send-bg: #f0efec;
        --send-ink: #171317;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }

      /* Hide native scrollbars but keep scrolling behavior */
      html {
        scrollbar-width: none; /* Firefox */
        -ms-overflow-style: none; /* IE 10+ */
        scroll-behavior: smooth;
      }
      html::-webkit-scrollbar { width: 0; height: 0; }
      body::-webkit-scrollbar { width: 0; height: 0; }

      body {
        font-family: 'Space Grotesk', 'Segoe UI', sans-serif;
        background: var(--bg);
        color: var(--ink);
        line-height: 1.65;
      }
      main {
        max-width: 1320px;
        margin: 0 auto;
        padding: 18px 28px 30px;
      }
      a { color: inherit; text-decoration: none; }
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        padding: 10px 14px;
        border: 1px solid var(--line);
        margin-bottom: 18px;
      }

      /* Explicit shared topbar typography to match homepage */
      .topbar,
      .topbar-block,
      .topbar-nav,
      .topbar-nav a {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.2em;
        line-height: 1;
        text-transform: uppercase;
        font-weight: 600;
      }

      .nav { display: flex; gap: 14px; }

      .topbar-nav {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .topbar-middle {
        text-align: center;
        flex: 1;
      }

      .topbar-nav {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .theme-toggle {
        border: 1px solid var(--line);
        border-radius: 999px;
        background: transparent;
        color: var(--ink);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        padding: 0;
        cursor: pointer;
      }

      .theme-toggle svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.8; }

      .theme-toggle .icon-sun { display: none; }
      html[data-theme='dark'] .theme-toggle .icon-sun { display: block; }
      html[data-theme='dark'] .theme-toggle .icon-moon { display: none; }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
      .meta {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
        margin-bottom: 8px;
      }
      h1 {
        margin: 0 0 10px;
        font-size: clamp(2rem, 5vw, 3.4rem);
        line-height: 0.95;
        letter-spacing: -0.04em;
      }
      .excerpt {
        margin: 0 0 24px;
        color: var(--muted);
      }
    </style>
  </head>
  <body>
    <main>
      <header class="topbar" aria-label="Site top bar">
        <div class="topbar-block">Debesh Biswas - The <em>B</em>log</div>
        <div class="topbar-block topbar-middle">Artificial Intelligence / Machine Learning</div>
        <nav class="topbar-block topbar-nav" aria-label="Primary">
          <a href="/home/">Console</a>
          <a href="/blog/">Disk</a>
          <a href="/about">Root</a>
          <button class="theme-toggle" id="themeToggle" type="button" aria-label="Switch to dark mode">
            <svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 13.2A9 9 0 1 1 10.8 3a7 7 0 0 0 10.2 10.2z"></path></svg>
            <svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v3M12 19v3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M2 12h3M19 12h3M4.9 19.1 7 17M17 7l2.1-2.1"></path></svg>
            <span class="visually-hidden">Toggle color theme</span>
          </button>
        </nav>
      </header>
      <div class="meta">{post.data.tag} · {formatDate(post.data.pubDate)}</div>
      <h1>{post.data.title}</h1>
      <p class="excerpt">{post.data.excerpt}</p>
      <Content />
    <script is:inline>
      const themeToggle = document.getElementById('themeToggle');
      const storedTheme = localStorage.getItem('debesh-blog-theme');
      const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.dataset.theme = storedTheme ?? (systemPrefersDark ? 'dark' : 'light');
      const updateThemeToggleLabel = (activeTheme) => {
        if (!(themeToggle instanceof HTMLButtonElement)) return;
        themeToggle.setAttribute(
          'aria-label',
          activeTheme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'
        );
      };
      themeToggle?.addEventListener('click', () => {
        const nextTheme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = nextTheme;
        localStorage.setItem('debesh-blog-theme', nextTheme);
        updateThemeToggleLabel(nextTheme);
      });
      updateThemeToggleLabel(document.documentElement.dataset.theme ?? 'light');
    </script>
    </main>
  </body>
</html>