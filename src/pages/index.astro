---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const siteTitle = "Debesh's Blog";
const siteDescription =
  'A personal blog born from an obsession with documentation and a deep interest in machine learning.';

const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    day: 'numeric',
    month: 'short',
    year: 'numeric'
  }).format(date);

const getPostSlug = (post: CollectionEntry<'blog'>) =>
  post.slug ?? post.id.replace(/\.mdx$/i, '').replace(/\/index$/i, '');

const toCard = (post: CollectionEntry<'blog'>) => ({
  title: post.data.title,
  tag: post.data.tag || '',
  heading: post.data.title,
  summary: post.data.excerpt || '',
  time: post.data.pubDate ? formatDate(post.data.pubDate) : '',
  href: `${import.meta.env.BASE_URL}blog/${getPostSlug(post)}/`
});

let featuredPosts = allPosts
  .filter((post) => post.data.featured)
  .slice(0, 4)
  .map(toCard);

const featuredSlugs = new Set(
  allPosts.filter((p) => p.data.featured).map((p) => getPostSlug(p))
);

let recentPosts = allPosts
  .filter((post) => !featuredSlugs.has(getPostSlug(post)))
  .slice(0, 4)
  .map(toCard);

if (recentPosts.length < 4) {
  const recentSlugs = new Set(recentPosts.map((r) => r.href));
  for (const p of allPosts) {
    if (recentPosts.length >= 4) break;
    const href = `${import.meta.env.BASE_URL}blog/${getPostSlug(p)}/`;
    if (recentSlugs.has(href)) continue;
    recentPosts.push(toCard(p));
    recentSlugs.add(href);
  }
}

if (featuredPosts.length === 0) {
  featuredPosts = allPosts.slice(0, 4).map(toCard);
}

const countdownTarget = '2042-01-01T00:00:00Z';
---

<BaseLayout title={siteTitle} description={siteDescription}>
  <section class="hero" aria-label="Hero">
    <div class="hero-left">
      <h1>Debesh's <span class="italic-b">B</span>log</h1>
      <p class="hero-copy">
        A personal blog born from an obsession with documentation and a deep interest in machine
        learning.
      </p>
    </div>

    <aside class="timer" aria-label="Countdown panel">
      <div class="timer-label">Time Until AI Takes Over The World and I Become a Farmer : </div>
      <div class="timer-value" id="countdown" data-target={countdownTarget} aria-live="polite">
        <span id="cd-days">00d</span>
        <span id="cd-hours">00h</span>
        <span id="cd-mins">00m</span>
        <span id="cd-secs">00s</span>
      </div>
    </aside>
  </section>

  <section class="section" aria-label="Featured posts">
    <div class="section-header">
      <div class="section-label">Featured</div>
      <div class="arrows">
        <button class="arrow-btn" data-direction="left" aria-label="Scroll left">←</button>
        <button class="arrow-btn" data-direction="right" aria-label="Scroll right">→</button>
      </div>
    </div>
    <div class="post-grid">
      {featuredPosts.map((post) => (
        <a class="post-card-link" href={post.href}>
          <article class="post-card">
            <div class="post-card-inner">
              <div class="post-top">{post.title}</div>
              <div class="post-bottom">
                <div class="post-meta">{post.tag}</div>
                <div class="post-summary">{post.summary}</div>
                <div class="post-time">{post.time}</div>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>
  </section>

  <section class="section" aria-label="Recent posts">
    <div class="section-header">
      <div class="section-label">Recent Posts</div>
      <div class="arrows">
        <button class="arrow-btn" data-direction="left" aria-label="Scroll left">←</button>
        <button class="arrow-btn" data-direction="right" aria-label="Scroll right">→</button>
      </div>
    </div>
    <div class="post-grid">
      {recentPosts.map((post) => (
        <a class="post-card-link" href={post.href}>
          <article class="post-card">
            <div class="post-card-inner">
              <div class="post-top">{post.title}</div>
              <div class="post-bottom">
                <div class="post-meta">{post.tag}</div>
                <div class="post-summary">{post.summary}</div>
                <div class="post-time">{post.time}</div>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>
  </section>

  <section class="newsletter" aria-label="Newsletter">
    <h2>Sign up for a weekly bite of curiosity in your inbox!</h2>
    <form class="newsletter-form" id="newsletterForm">
      <input type="email" id="newsletterEmail" aria-label="Email" placeholder="Your email" required />
      <button type="submit" id="newsletterBtn">SEND</button>
    </form>
    <p class="newsletter-msg" id="newsletterMsg" aria-live="polite"></p>
  </section>

  <script is:inline>
    (function () {
      const form = document.getElementById('newsletterForm');
      const input = document.getElementById('newsletterEmail');
      const btn = document.getElementById('newsletterBtn');
      const msg = document.getElementById('newsletterMsg');

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        btn.textContent = '...';
        btn.disabled = true;
        msg.textContent = '';

        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: input.value.trim() }),
          });
          const data = await res.json();
          if (data.success) {
            msg.textContent = 'Subscribed! You\'ll hear from me when new posts go live.';
            msg.style.color = 'var(--ink)';
            form.style.display = 'none';
          } else {
            msg.textContent = data.error ?? 'Something went wrong. Try again.';
            msg.style.color = '#c0392b';
            btn.textContent = 'SEND';
            btn.disabled = false;
          }
        } catch {
          msg.textContent = 'Network error. Please try again.';
          msg.style.color = '#c0392b';
          btn.textContent = 'SEND';
          btn.disabled = false;
        }
      });
    })();
  </script>

  <script is:inline>
    const countdownElement = document.getElementById('countdown');

    const formatCountdown = (targetDate) => {
      const now = new Date();
      const diff = Math.max(0, targetDate.getTime() - now.getTime());
      const s = Math.floor(diff / 1000);
      return {
        days: String(Math.floor(s / 86400)).padStart(2, '0'),
        hours: String(Math.floor((s % 86400) / 3600)).padStart(2, '0'),
        minutes: String(Math.floor((s % 3600) / 60)).padStart(2, '0'),
        seconds: String(s % 60).padStart(2, '0')
      };
    };

    const renderCountdown = () => {
      if (!countdownElement) return;
      const target = new Date(countdownElement.dataset.target ?? '2042-01-01T00:00:00Z');
      const value = formatCountdown(target);
      document.getElementById('cd-days').textContent = value.days + 'd';
      document.getElementById('cd-hours').textContent = value.hours + 'h';
      document.getElementById('cd-mins').textContent = value.minutes + 'm';
      document.getElementById('cd-secs').textContent = value.seconds + 's';
    };

    let countdownInterval = null;
    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        renderCountdown();
        countdownInterval = setInterval(renderCountdown, 1000);
      } else {
        clearInterval(countdownInterval);
      }
    }, { threshold: 0 });

    if (countdownElement) observer.observe(countdownElement);

    (function () {
      const sections = document.querySelectorAll('.section');
      sections.forEach((section) => {
        const grid = section.querySelector('.post-grid');
        if (!grid) return;

        const leftBtn = section.querySelector('.arrow-btn[data-direction="left"]');
        const rightBtn = section.querySelector('.arrow-btn[data-direction="right"]');

        const getScrollAmount = () => Math.max(300, Math.floor(grid.clientWidth * 0.9));

        const doScroll = (dir) => {
          const amount = getScrollAmount();
          grid.scrollBy({ left: dir === 'left' ? -amount : amount, behavior: 'smooth' });
        };

        leftBtn?.addEventListener('click', () => doScroll('left'));
        rightBtn?.addEventListener('click', () => doScroll('right'));
      });
    })();
  </script>
</BaseLayout>

<style>
  .italic-b {
    font-style: italic;
    margin-right: 0.08em;
    margin-left: -0.08em;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.03fr 1.34fr;
    gap: 24px;
    align-items: stretch;
    padding: 10px 0 14px;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  h1 {
    font-size: clamp(4.1rem, 9vw, 7.4rem);
    line-height: 0.86;
    letter-spacing: -0.055em;
    margin: 0;
    font-weight: 700;
    max-width: 7ch;
  }

  .hero-copy {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 1.45rem;
    line-height: 1.16;
    letter-spacing: 0.02em;
    color: var(--ink-soft);
    max-width: 34ch;
  }

  .timer {
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 30px 28px;
    background: var(--surface);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    min-height: 100%;
  }

  .timer-label {
    font-family: 'Google Sans Code', 'IBM Plex Mono', monospace;
    font-size: 0.82rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 12px;
    color: var(--ink-soft);
    text-wrap: balance;
  }

  .timer-value {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(3.6rem, 6.8vw, 6.4rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    text-wrap: balance;
    white-space: nowrap;
  }

  .timer-value span {
    display: inline-block;
    min-width: 1.9ch;
  }

  .section {
    padding: 12px 0 12px;
    border-top: 1px solid var(--line);
    overflow: visible;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }

  .section-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    font-weight: 600;
    text-transform: uppercase;
  }

  .arrows {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .arrow-btn {
    background: transparent;
    border: none;
    color: var(--ink);
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 1rem;
    padding: 0;
  }

  .arrow-btn:focus { outline: none; }
  .arrow-btn:focus-visible { outline: 2px solid var(--line); outline-offset: 2px; }

  .post-grid {
    display: flex;
    flex-direction: row;
    gap: 20px;
    align-items: stretch;
    overflow-x: auto;
    overflow-y: visible;
    padding-inline: 18px;
    padding-top: 18px;
    scroll-behavior: smooth;
    padding-bottom: 24px;
    -webkit-overflow-scrolling: touch;
    flex-wrap: nowrap;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .post-grid::-webkit-scrollbar { display: none; }

  .post-card {
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--surface);
    height: 100%;
    display: flex;
    flex-direction: column;
    width: 360px;
    flex: 0 0 360px;
    box-sizing: border-box;
    position: relative;
    transition: transform 320ms cubic-bezier(.2,.9,.2,1), border-color 320ms ease, box-shadow 320ms ease;
    transform-origin: center;
    will-change: transform, border-color, box-shadow;
    -webkit-font-smoothing: antialiased;
  }

  .post-card:hover,
  .post-card:focus-within {
    transform: translateY(-6px) scale(1.01);
    box-shadow: var(--shadow-elev-1), var(--shadow-glow);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .post-card > * { position: relative; z-index: 2; }
  .post-card-inner {
    border-radius: 14px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .post-card-inner > * { position: relative; z-index: 2; }

  @media (prefers-reduced-motion: reduce) {
    .post-card,
    .post-card:hover,
    .post-card:focus-within {
      transition: none !important;
      transform: none !important;
    }
  }

  .post-card-link {
    display: block;
    color: inherit;
    height: 100%;
  }

  .post-top {
    padding: 16px 14px 14px;
    background: var(--card-top);
    color: var(--card-top-ink);
    font-size: 2.4rem;
    line-height: 0.95;
    letter-spacing: -0.03em;
    min-height: 150px;
    display: flex;
    align-items: flex-end;
  }

  .post-bottom {
    padding: 10px 14px 12px;
    flex: 1;
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    align-content: start;
  }

  .post-meta {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.56rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 8px;
  }

  .post-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 3px;
  }

  .post-summary,
  .post-time {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.74rem;
    color: var(--ink-soft);
  }

  .newsletter {
    padding: 14px 0 12px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 12px;
    align-items: center;
  }

  .newsletter h2 {
    font-size: clamp(1.55rem, 2vw, 2.15rem);
    line-height: 1.02;
    letter-spacing: -0.055em;
    margin: 0;
  }

  .newsletter-form {
    display: flex;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 15px;
    background: var(--input-bg);
    overflow: hidden;
    width: 100%;
    min-height: 56px;
    flex: 0 0 auto;
    justify-self: end;
    padding: 4px;
  }

  .newsletter-form input {
    flex: 1;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--ink);
    font: inherit;
    font-size: 0.95rem;
    padding: 10px 18px;
  }

  .newsletter-form input::placeholder {
    color: var(--ink-soft);
    opacity: 0.75;
  }

  .newsletter-form button {
    border: 0;
    background: var(--send-bg);
    color: var(--send-ink);
    padding: 10px 18px;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    min-width: 84px;
    border-radius: 11px;
    transition: opacity 150ms ease;
  }

  .newsletter-form button:disabled {
    opacity: 0.5;
    cursor: default;
  }

  .newsletter-msg {
    grid-column: 1 / -1;
    margin: 0;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.82rem;
  }

  @media (max-width: 1140px) {
    .hero { grid-template-columns: 1fr; }
    h1 { margin-bottom: 16px; }
  }

  @media (max-width: 740px) {
    .timer-value { font-size: clamp(3.2rem, 14vw, 5.6rem); }
    .newsletter { grid-template-columns: 1fr; gap: 16px; }
    .newsletter h2 { font-size: clamp(1.55rem, 8vw, 2.1rem); }
  }
</style>
