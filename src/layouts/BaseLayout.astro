---
interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans+Code:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500;600&family=Instrument+Serif:ital@0;1&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="alternate" type="application/rss+xml" title="Debesh's Blog" href={`${import.meta.env.BASE_URL}rss.xml`} />
    <script is:inline>
      const storedTheme = localStorage.getItem('debesh-blog-theme');
      const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.dataset.theme = storedTheme ?? (systemPrefersDark ? 'dark' : 'light');
    </script>
    <title>{title}</title>
    <style is:global>
      :root {
        --bg: #f0ede8;
        --surface: #e5e7ea;
        --ink: #151112;
        --ink-soft: #383336;
        --line: #a7a2a5;
        --card-top: linear-gradient(180deg, #2d2a2c 0%, #161417 100%);
        --card-top-ink: #f2f2f2;
        --input-bg: #e5e7ea;
        --send-bg: #130f11;
        --send-ink: #f6f4f2;
        --shadow-elev-1: 0 8px 22px -14px rgba(0, 0, 0, 0.8);
        --shadow-glow: 0 4px 12px -10px rgba(255, 255, 255, 0.18);
        --muted: #383336;
        --border: #a7a2a5;
      }

      html[data-theme='dark'] {
        color-scheme: dark;
        --bg: #0d0d11;
        --surface: #1a1c1e;
        --ink: #f2f0ee;
        --ink-soft: #d0ccd1;
        --line: #565259;
        --card-top: linear-gradient(180deg, #f0f0f0 0%, #d8dbe0 100%);
        --card-top-ink: #191519;
        --input-bg: #11131a;
        --send-bg: #f0efec;
        --send-ink: #171317;
        --shadow-elev-1: 0 10px 28px -14px rgba(0, 0, 0, 0.75);
        --shadow-glow: 0 10px 20px -10px rgba(255, 255, 255, 0.75);
        --muted: #d0ccd1;
        --border: #565259;
      }

      html[data-theme='light'] {
        color-scheme: light;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }

      html {
        scrollbar-width: none;
        -ms-overflow-style: none;
        scroll-behavior: smooth;
      }
      html::-webkit-scrollbar { width: 0; height: 0; }
      body::-webkit-scrollbar { width: 0; height: 0; }

      body {
        font-family: 'Space Grotesk', 'Segoe UI', sans-serif;
        background: var(--bg);
        color: var(--ink);
        line-height: 1.3;
      }

      main {
        max-width: 1320px;
        margin: 0 auto;
        padding: 18px 28px 30px;
      }

      a { text-decoration: none; color: inherit; }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        padding: 10px 14px;
        border: 1px solid var(--line);
        margin-bottom: 18px;
      }

      .topbar-block {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        font-weight: 600;
        white-space: nowrap;
      }

      .topbar-middle {
        text-align: center;
        flex: 1;
      }

      .topbar-nav {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .theme-toggle {
        border: 1px solid var(--line);
        border-radius: 999px;
        background: transparent;
        color: var(--ink);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        padding: 0;
        cursor: pointer;
      }

      .theme-toggle svg {
        width: 18px;
        height: 18px;
        stroke: currentColor;
        fill: none;
        stroke-width: 1.8;
      }

      .theme-toggle .icon-sun { display: none; }
      html[data-theme='dark'] .theme-toggle .icon-sun { display: block; }
      html[data-theme='dark'] .theme-toggle .icon-moon { display: none; }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      @media (max-width: 740px) {
        main { padding-inline: 14px; }
        .topbar { flex-wrap: wrap; justify-content: center; }
        .topbar-middle { order: 3; width: 100%; }
        .theme-toggle { width: 40px; height: 40px; justify-content: center; }
      }
    </style>
  </head>
  <body>
    <main>
      <header class="topbar" aria-label="Site top bar">
        <div class="topbar-block">Debesh Biswas - The <em>B</em>log</div>
        <div class="topbar-block topbar-middle">Artificial Intelligence / Machine Learning</div>
        <nav class="topbar-block topbar-nav" aria-label="Primary">
          <a href={`${import.meta.env.BASE_URL}`}>Console</a>
          <a href={`${import.meta.env.BASE_URL}blog`}>Disk</a>
          <a href={`${import.meta.env.BASE_URL}about`}>Root</a>
          <button class="theme-toggle" id="themeToggle" type="button" aria-label="Switch to dark mode">
            <svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M21 13.2A9 9 0 1 1 10.8 3a7 7 0 0 0 10.2 10.2z"></path>
            </svg>
            <svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v3M12 19v3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M2 12h3M19 12h3M4.9 19.1 7 17M17 7l2.1-2.1"></path>
            </svg>
            <span class="visually-hidden">Toggle color theme</span>
          </button>
        </nav>
      </header>
      <slot />
    </main>
    <script>
      import { initTheme } from '../scripts/theme.ts';
      initTheme();
    </script>
  </body>
</html>
